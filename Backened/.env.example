# GramWork Microservices Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# Spring Profiles
# ============================================
SPRING_PROFILES_ACTIVE=docker

# ============================================
# MongoDB Configuration
# ============================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ============================================
# Config Server Credentials
# ============================================
CONFIG_USERNAME=config
CONFIG_PASSWORD=config123

# ============================================
# Eureka Server Credentials
# ============================================
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=eureka123

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=gramwork-secret-key-for-authentication-change-in-production

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ============================================
# SMS Configuration (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Push Notification (FCM)
# ============================================
FCM_SERVER_KEY=your-fcm-server-key

# ============================================
# Payment Gateway Configuration
# ============================================
# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Stripe
STRIPE_API_KEY=your-stripe-api-key

# ============================================
# Frontend URL (for CORS)
# ============================================
FRONTEND_URL=http://localhost:3000
